        {"id": "stage_00.import_concept", "type": "import_or_design_doc", "description": "Import concept artifacts when provided, otherwise use the current project design document."},
        {"id": "stage_00.generate_design_machine_files", "type": "deterministic_generation", "description": "Generate design source manifest, extraction, option coverage, project selections, open questions, scope catalog, and phase map."}
      ],
      "reviewers": ["structure_reviewer", "source_trace_reviewer", "task_reviewer", "dependency_reviewer"],
      "validators": ["validator_first_contract", "stage_files_validator", "review_report_validator", "manifest_validator", "knowledge_refs_validator", "dependency_status_validator"],
      "knowledge_refs": ["knowledge/Core_Rules.md", "knowledge/Frozen_Contracts.md", "knowledge/Naming_Convention.md"]
    },
    {
      "id": "stage_01.gameplay_framework_bundle",
      "stage": 1,
      "kind": "framework_graph_bundle",
