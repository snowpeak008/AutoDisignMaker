        {"id": "stage_02.import_subsystems", "type": "import", "description": "Import subsystem designs."},
        {"id": "stage_02.import_ai_design_script", "type": "import", "description": "Import AI design script."},
        {"id": "stage_02.import_development_design", "type": "import", "description": "Import frozen design and development design artifacts."},
