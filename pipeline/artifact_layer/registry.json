    "structure_reviewer",
    "source_trace_reviewer",
    "task_reviewer",
    "dependency_reviewer"
  ],
  "default_validators": [
    "validator_first_contract",
    "stage_files_validator",
    "review_report_validator",
    "manifest_validator",
    "knowledge_refs_validator",
    "dependency_status_validator"
