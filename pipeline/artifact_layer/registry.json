      "tasks": [
        {"id": "stage_01.import_framework_history", "type": "import_or_reference", "description": "Import gameplay framework history when provided or reference validated stage 00 outputs."},
        {"id": "stage_01.generate_framework_graphs", "type": "deterministic_generation", "description": "Generate gameplay framework, core loop, system boundary, full feature scope, implementation phase map, system relation graph, and resource flow graph."}
      ],
      "reviewers": ["structure_reviewer", "source_trace_reviewer", "task_reviewer", "dependency_reviewer"],
      "validators": ["validator_first_contract", "stage_files_validator", "review_report_validator", "manifest_validator", "knowledge_refs_validator", "dependency_status_validator"],
