        "test_report_json_schema_valid"
      ]
    }
  },

  "acceptance_criteria": {
    "functional": [
      "占位符率 >50% 的输入返回 BLOCKED 裁决",
      "BLOCKED 裁决阻止流水线继续",
      "评审报告包含所有 Finding 的 severity/category/message",
      "score 计算与 BLOCKER/CRITICAL/WARNING 计数一致",
      "新生成的规范需求返回 PASS 或 WARN"
    ]
  },

  "target_metrics": {
    "step05_warnings": "107 → <15",
    "false_pass_rate": "100% → 0%",
    "blocker_detection_rate": "0% → 100%"
  }
}
