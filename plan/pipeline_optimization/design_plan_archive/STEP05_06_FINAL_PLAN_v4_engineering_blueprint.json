      ]
    },
    "integration": {
      "test_step05_integration.py": [
        "test_old_placeholder_requirements_blocked",
        "test_new_bound_requirements_pass",
        "test_report_json_schema_valid"
      ],
      "test_step06_integration.py": [
        "test_old_3_assets_blocked",
