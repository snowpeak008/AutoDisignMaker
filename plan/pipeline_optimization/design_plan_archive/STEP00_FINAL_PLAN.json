  "solution": {
    "new_modules": {
      "ConceptProcessor": {
        "file": "core/concept_processor.py",
        "purpose": "解析concept.md，从DesignEngine获取选项详情",
        "key_methods": [
          "process(source_dir) -> ConceptData",
          "_get_option_detail(domain, decision, option_id) -> dict",
          "_enrich_with_design_options(concept) -> ConceptData"
        ],
        "codex_feedback": "Add @lru_cache to _get_option_detail for performance"
      },
      "QuestionEngine": {
        "file": "core/question_engine.py",
        "purpose": "管理15个问题，计算覆盖率，生成引导",
        "key_methods": [
          "get_coverage_rate() -> float",
          "get_unanswered_questions() -> List[DesignQuestion]",
          "generate_gap_analysis() -> dict"
        ],
        "codex_feedback": "Load questions from data/core_questions.json instead of hardcoding"
      },
      "CodexAdapter": {
        "file": "adapters/codex_adapter.py",
        "purpose": "Codex CLI集成，带缓存和回退",
        "key_methods": [
          "run_guided_interview(questions, context, fallback) -> dict"
        ],
        "codex_feedback": "MUST implement retry mechanism + fallback strategy"
      },
      "ContentGenerator": {
        "file": "core/content_generator.py",
        "purpose": "基于问答生成完整设计内容",
        "key_methods": [
          "generate(concept, question_engine) -> dict"
        ]
      }
    },
    "data_files": {
      "core_questions.json": {
        "path": "data/core_questions.json",
        "purpose": "15个核心问题定义（从代码分离）",
        "structure": {
          "version": "1.0",
          "questions": [
            {
              "id": "Q01-Q15",
              "ref": "question_ref",
              "domain": "项目愿景/核心体验/系统图",
              "decision": "决策节点",
              "question": "问题文本",
              "priority": "critical/high/medium/low",
              "guidance": "引导说明",
              "examples": [
                "示例1",
                "示例2"
              ]
            }
          ]
        }
      }
    },
    "codex_integration": {
      "trigger": "coverage < 40%",
      "task_type": "guided_interview",
      "input": {
        "unanswered_questions": "List[dict]",
        "current_context": "已有答案的dict"
      },
      "output": {
        "answers": "补全的答案dict"
      },
      "error_handling": {
        "retry": "3次，指数退避",
        "fallback": "使用通用答案或跳过",
        "cache": "缓存成功的响应"
      }
    },
    "standard_structure": [
      "core/ - 核心逻辑",
      "adapters/ - 适配器层",
      "schemas/ - 数据结构",
      "prompts/ - AI提示词",
      "data/ - 配置数据",
      "tests/ - 测试用例"
    ]
  },
