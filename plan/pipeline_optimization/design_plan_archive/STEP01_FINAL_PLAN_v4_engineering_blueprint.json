{
  "step": "01",
  "name": "玩法框架 (Gameplay Framework)",
  "version": "v4.0 Engineering Blueprint",
  "status": "pending",
  "priority": "critical",

  "problems": {
    "current_issues": [
      "core_loop.json 完全为空（loop: []）",
      "无 systems.json 输出",
      "不读取步骤00输出数据",
      "无品类模板库"
    ],
    "root_causes": [
      "plugin.py 未实现数据继承链",
      "无循环提取和系统推导算法"
    ]
  },

  "module_structure": {
    "root": "pipeline/step_01_gameplay_framework/",
    "files": {
      "plugin.py": {
        "class": "Plugin",
        "inherits": "StagePlugin",
        "stage_id": "1",
        "responsibility": "编排层：调用 DataInheritor → LoopExtractor → SystemDeducer → ResourceAnalyzer",
        "execute_body_outline": [
          "1. run_import_step() 导入源包",
          "2. DataInheritor(ctx).load() → step00_data",
          "3. LoopExtractor(templates_path).extract(step00_data) → loop",
          "4. if loop.is_ai_needed: AIAdapter(ctx).extract_loop(step00_data) → loop",
          "5. SystemDeducer(templates_path).deduce(loop, step00_data) → systems",
          "6. ResourceAnalyzer.analyze(loop, systems) → resource_flows",
          "7. 组装输出，验证 schema",
          "8. return StageResult"
        ]
      },
      "core/inheritor.py": {
        "class": "DataInheritor",
        "docstring": "加载步骤00输出，验证 Schema，提供强类型访问接口",
        "methods": [
          {
            "name": "load",
            "signature": "(self) -> Step00Data",
            "raises": "DataInheritanceError if step00 output missing or schema invalid"
          },
          {
            "name": "_validate_schema",
            "signature": "(self, data: dict) -> None"
          }
        ],
        "data_class": {
          "name": "Step00Data",
          "fields": {
            "project_name": "str",
            "genre": "str",
            "core_vision": "str",
            "enriched_options": "dict",
            "question_answers": "dict",
            "coverage_rate": "float"
          }
        }
      },
      "core/loop_extractor.py": {
        "class": "LoopExtractor",
        "docstring": "从概念数据推导核心游戏循环；优先使用显式答案，其次使用品类模板",
        "init_signature": "(self, templates_path: Path)",
        "methods": [
          {
            "name": "extract",
            "signature": "(self, data: Step00Data) -> CoreLoopResult",
            "algorithm": "1. 从 question_answers 查找核心循环相关答案; 2. 解析循环节点; 3. 若答案不足则从 genre_templates 填充缺失节点"
          },
          {
            "name": "_parse_loop_from_answers",
            "signature": "(self, answers: dict) -> list[LoopNode] | None"
          },
          {
            "name": "_fill_from_genre_template",
            "signature": "(self, genre: str, partial_nodes: list[LoopNode]) -> list[LoopNode]"
          }
        ],
        "data_classes": {
          "LoopNode": {
            "fields": {
              "id": "str",
              "name": "str",
              "type": "Literal['action','feedback','reward','decision']",
              "duration_seconds": "int | None",
              "connects_to": "list[str]"
            }
          },
          "CoreLoopResult": {
            "fields": {
              "nodes": "list[LoopNode]",
              "primary_loop_seconds": "int",
              "secondary_loops": "list[dict]",
              "source": "Literal['explicit','template','ai']",
              "is_ai_needed": "bool"
            }
          }
        }
      },
      "core/system_deducer.py": {
        "class": "SystemDeducer",
        "docstring": "基于核心循环和品类模板推导游戏系统列表",
        "init_signature": "(self, templates_path: Path)",
        "methods": [
          {
            "name": "deduce",
            "signature": "(self, loop: CoreLoopResult, data: Step00Data) -> list[GameSystem]"
          },
          {
            "name": "_select_template",
            "signature": "(self, genre: str) -> GenreTemplate"
          },
          {
            "name": "_map_loop_to_systems",
            "signature": "(self, loop: CoreLoopResult, template: GenreTemplate) -> list[GameSystem]"
          },
          {
            "name": "_resolve_dependencies",
            "signature": "(self, systems: list[GameSystem]) -> list[GameSystem]",
            "note": "拓扑排序，确保依赖关系合法"
          }
        ],
        "data_classes": {
          "GameSystem": {
            "fields": {
              "id": "str",
              "name": "str",
              "type": "Literal['core','support','meta','social','progression']",
              "description": "str",
              "depends_on": "list[str]",
              "loop_nodes": "list[str]",
              "complexity": "Literal['low','medium','high']"
            }
          },
          "GenreTemplate": {
            "fields": {
              "genre": "str",
              "required_systems": "list[str]",
              "optional_systems": "list[str]",
              "typical_loop_seconds": "int",
              "reference_games": "list[str]"
            }
          }
        }
      },
      "core/resource_analyzer.py": {
        "class": "ResourceAnalyzer",
        "docstring": "分析系统间资源流动，生成资源流图",
        "methods": [
          {
            "name": "analyze",
            "signature": "(self, loop: CoreLoopResult, systems: list[GameSystem]) -> ResourceFlowMap"
          },
          {
            "name": "_identify_resources",
            "signature": "(self, systems: list[GameSystem]) -> list[Resource]"
          },
          {
            "name": "_trace_flows",
            "signature": "(self, resources: list[Resource], systems: list[GameSystem]) -> list[ResourceFlow]"
          }
        ],
        "data_classes": {
          "Resource": {
            "fields": {
              "id": "str",
              "name": "str",
              "type": "Literal['currency','experience','item','progression','social']",
              "producers": "list[str]",
              "consumers": "list[str]"
            }
          },
          "ResourceFlow": {
            "fields": {
              "from_system": "str",
              "to_system": "str",
              "resource_id": "str",
              "flow_type": "Literal['produces','consumes','transforms']"
            }
          },
          "ResourceFlowMap": {
            "fields": {
              "resources": "list[Resource]",
              "flows": "list[ResourceFlow]",
              "mermaid_diagram": "str"
            }
          }
        }
      },
      "adapters/ai_adapter.py": {
        "class": "LoopExtractionAdapter",
        "methods": [
          {
            "name": "extract_loop",
            "signature": "(self, data: Step00Data) -> list[LoopNode]",
            "fallback": "load from genre_templates.json"
          },
          {
            "name": "suggest_systems",
            "signature": "(self, loop: CoreLoopResult, genre: str) -> list[dict]"
          }
        ]
      }
    }
  },

  "data_files": {
    "data/genre_templates.json": {
      "purpose": "5个品类的系统模板和循环模板",
      "genres": ["roguelike", "fps", "rpg", "puzzle", "strategy"],
      "per_genre_fields": {
        "required_systems": "必须有的核心系统",
        "optional_systems": "可选系统",
        "loop_template": "标准循环节点",
        "typical_session_seconds": "典型游戏时长",
        "reference_games": ["代表作1", "代表作2"]
      }
    }
  },

  "data_contracts": {
    "input": {
      "from_step_00": "sandbox/outputs/artifacts/stage_00/design_extraction_enhanced.json",
      "schema_validation": "strict - DataInheritanceError on mismatch"
    },
    "output": {
      "core_loop.json": {
        "required_fields": ["nodes", "primary_loop_seconds", "source"],
        "constraint": "nodes must not be empty"
      },
      "systems.json": {
        "required_fields": ["systems", "total_count"],
        "constraint": "3 <= total_count <= 8"
      },
      "resource_flows.json": {
        "required_fields": ["resources", "flows", "mermaid_diagram"]
      }
    }
  },

  "implementation_tasks": [
    {"id": "T01-01", "task": "创建五层模块目录结构", "hours": 1, "status": "pending"},
    {"id": "T01-02", "task": "实现 Step00Data dataclass + DataInheritor.load()", "hours": 3, "status": "pending"},
    {"id": "T01-03", "task": "实现 LoopNode + CoreLoopResult dataclass", "hours": 1, "status": "pending"},
    {"id": "T01-04", "task": "实现 LoopExtractor._parse_loop_from_answers()", "hours": 3, "status": "pending"},
    {"id": "T01-05", "task": "创建 data/genre_templates.json（5个品类完整定义）", "hours": 4, "status": "pending"},
    {"id": "T01-06", "task": "实现 LoopExtractor._fill_from_genre_template()", "hours": 2, "status": "pending"},
    {"id": "T01-07", "task": "实现 LoopExtractor.extract()", "hours": 2, "status": "pending"},
    {"id": "T01-08", "task": "实现 GameSystem + GenreTemplate dataclass", "hours": 1, "status": "pending"},
    {"id": "T01-09", "task": "实现 SystemDeducer._select_template() + _map_loop_to_systems()", "hours": 4, "status": "pending"},
    {"id": "T01-10", "task": "实现 SystemDeducer._resolve_dependencies()（拓扑排序）", "hours": 3, "status": "pending"},
    {"id": "T01-11", "task": "实现 ResourceAnalyzer 全部方法", "hours": 4, "status": "pending"},
    {"id": "T01-12", "task": "实现 LoopExtractionAdapter（含回退）", "hours": 3, "status": "pending"},
    {"id": "T01-13", "task": "重构 plugin.py 为编排层", "hours": 2, "status": "pending"},
    {"id": "T01-14", "task": "单元测试（LoopExtractor 5个用例）", "hours": 3, "status": "pending"},
    {"id": "T01-15", "task": "单元测试（SystemDeducer 4个用例）", "hours": 2, "status": "pending"},
