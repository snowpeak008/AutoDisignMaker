{
  "step": "03",
  "name": "程序需求 (Program Requirements)",
  "version": "v4.0 Engineering Blueprint",
  "status": "pending",
  "priority": "high",

  "problems": {
    "current_issues": [
      "107条需求全是占位符字符串",
      "所有需求未绑定系统（107个 PROGREQ-NO-SYSTEM 警告）",
      "无法从 designEntities 提取功能需求",
      "无需求完整性验证"
    ],
    "root_causes": [
      "无实体→需求转换器",
      "无系统绑定逻辑",
      "plugin.py 仅调用骨架模板"
    ]
  },

  "module_structure": {
    "root": "pipeline/step_03_program_requirements/",
    "files": {
      "plugin.py": {
        "class": "Plugin",
        "inherits": "StagePlugin",
        "stage_id": "3",
        "execute_body_outline": [
          "1. run_import_step()",
          "2. step02_data = DataInheritor(ctx).load()",
          "3. registry = ConverterRegistry.load(converters_dir)",
          "4. requirements = EntityToRequirementConverter(registry).convert_all(step02_data.entities)",
          "5. if placeholder_rate > 0.80: AIAdapter(ctx).generate_requirements(step02_data)",
          "6. bound = SystemBinder(step02_data.systems).bind(requirements)",
          "7. validation = RequirementValidator.validate(bound)",
          "8. 写出文件，return StageResult"
        ]
      },
      "core/converter_registry.py": {
        "class": "ConverterRegistry",
        "docstring": "注册表模式：管理 15+ 种 entity schema 到需求的转换器",
        "methods": [
          {
            "name": "load",
            "signature": "(cls, converters_dir: Path) -> ConverterRegistry",
            "note": "扫描 converters_dir/*.py，自动注册所有 BaseConverter 子类"
          },
          {
            "name": "get",
            "signature": "(self, schema_type: str) -> BaseConverter",
            "fallback": "若无匹配则返回 GenericConverter"
          },
          {
            "name": "register",
            "signature": "(self, schema_type: str, converter: BaseConverter) -> None"
          }
        ]
      },
      "core/base_converter.py": {
        "class": "BaseConverter",
        "docstring": "所有实体→需求转换器的抽象基类",
        "abstract_methods": [
          {
            "name": "schema_type",
            "type": "ClassVar[str]",
            "note": "每个子类必须声明支持的 entity schema 类型"
          },
          {
            "name": "convert",
            "signature": "(self, entity: DesignEntity) -> list[ProgramRequirement]"
          }
        ],
        "data_class": {
          "name": "ProgramRequirement",
          "fields": {
            "id": "str",
            "title": "str",
            "description": "str",
            "acceptance_criteria": "list[str]",
            "system_id": "str | None",
            "entity_id": "str",
            "priority": "Literal['P0','P1','P2','P3']",
            "complexity": "Literal['xs','s','m','l','xl']",
            "is_placeholder": "bool"
          }
        }
      },
      "core/converters/skill_card_converter.py": {
        "class": "SkillCardConverter",
        "schema_type": "skill_card",
        "convert_logic": "skill_name → 3条需求：触发逻辑/效果计算/UI展示"
      },
      "core/converters/character_card_converter.py": {
        "class": "CharacterCardConverter",
        "schema_type": "character_card",
        "convert_logic": "character attributes → 需求：属性系统/成长曲线/状态机"
      },
      "core/converters/item_card_converter.py": {
        "class": "ItemCardConverter",
        "schema_type": "item_card",
        "convert_logic": "item properties → 需求：拾取/使用/持久化/掉落"
      },
      "core/converters/system_card_converter.py": {
        "class": "SystemCardConverter",
        "schema_type": "system_card",
        "convert_logic": "system definition → 需求：状态管理/事件/数据持久化"
      },
      "core/converters/operation_card_converter.py": {
        "class": "OperationCardConverter",
        "schema_type": "operation_card",
        "convert_logic": "operation definition → 需求：输入处理/动画/音效触发"
      },
      "core/converters/generic_converter.py": {
        "class": "GenericConverter",
        "schema_type": "_generic",
        "note": "兜底转换器：从 entity name + attributes 生成通用需求格式"
      },
      "core/system_binder.py": {
        "class": "SystemBinder",
        "docstring": "将需求绑定到对应系统：精确匹配 → 模糊匹配 → 未绑定",
        "init_signature": "(self, systems: list[GameSystem])",
        "methods": [
          {
            "name": "bind",
            "signature": "(self, requirements: list[ProgramRequirement]) -> list[ProgramRequirement]"
          },
          {
            "name": "_exact_match",
            "signature": "(self, req: ProgramRequirement) -> str | None",
            "note": "entity.system_id 直接查系统表"
          },
          {
            "name": "_fuzzy_match",
            "signature": "(self, req: ProgramRequirement) -> str | None",
            "algorithm": "token overlap between req.title and system.name/keywords"
          }
        ]
      },
      "core/requirement_validator.py": {
        "class": "RequirementValidator",
        "methods": [
          {
            "name": "validate",
            "signature": "(cls, requirements: list[ProgramRequirement]) -> ValidationReport"
          }
        ],
        "data_class": {
          "name": "ValidationReport",
          "fields": {
            "total": "int",
            "placeholder_count": "int",
            "placeholder_rate": "float",
            "unbound_count": "int",
            "binding_rate": "float",
            "missing_acceptance_criteria": "list[str]"
          }
        }
      },
      "adapters/ai_adapter.py": {
        "class": "RequirementGenerationAdapter",
        "methods": [
          {
            "name": "generate_requirements",
            "signature": "(self, step02_data: Step02Data) -> list[dict]",
            "fallback": "返回带通用验收标准的占位需求"
          }
        ]
      }
    }
  },

  "converter_registry_plan": {
    "phase_1_week_6": ["skill_card", "character_card", "item_card", "system_card", "operation_card"],
    "phase_2_week_7": ["level_card", "ui_card", "event_card", "quest_card", "economy_card"],
    "phase_3_future": "remaining schemas from knowledge/schemas/",
    "generic_fallback": "GenericConverter handles any unregistered schema"
  },

  "data_contracts": {
    "input": {
      "from_step_02": ["frozen_design.json", "design_entities.json", "systems.json (via step_01)"]
    },
    "output": {
      "program_requirements.md": "人类可读需求文档",
      "program_requirements_enhanced.json": "结构化需求（含 system_id、entity_id）",
      "requirements_by_system.json": "按系统分组的需求索引",
      "requirement_validation_report.json": "验证报告"
    }
  },

  "implementation_tasks": [
    {"id": "T03-01", "task": "创建五层模块目录结构 + converters 子目录", "hours": 1, "status": "pending"},
    {"id": "T03-02", "task": "实现 ProgramRequirement dataclass + ValidationReport", "hours": 2, "status": "pending"},
    {"id": "T03-03", "task": "实现 BaseConverter 抽象基类", "hours": 2, "status": "pending"},
    {"id": "T03-04", "task": "实现 ConverterRegistry.load() + get() + register()", "hours": 3, "status": "pending"},
    {"id": "T03-05", "task": "实现5个核心转换器（skill/character/item/system/operation）", "hours": 8, "status": "pending"},
    {"id": "T03-06", "task": "实现 GenericConverter（兜底）", "hours": 2, "status": "pending"},
    {"id": "T03-07", "task": "实现 SystemBinder._exact_match() + _fuzzy_match() + bind()", "hours": 4, "status": "pending"},
    {"id": "T03-08", "task": "实现 RequirementValidator.validate()", "hours": 2, "status": "pending"},
    {"id": "T03-09", "task": "实现 RequirementGenerationAdapter（含回退）", "hours": 3, "status": "pending"},
    {"id": "T03-10", "task": "重构 plugin.py 为编排层", "hours": 2, "status": "pending"},
    {"id": "T03-11", "task": "单元测试（每个转换器2个用例 = 10个用例）", "hours": 5, "status": "pending"},
    {"id": "T03-12", "task": "单元测试（SystemBinder 4个用例含模糊匹配）", "hours": 3, "status": "pending"},
    {"id": "T03-13", "task": "集成测试（Hades模板需求生成全流程）", "hours": 3, "status": "pending"}
  ],

  "test_cases": {
    "unit": {
      "test_converter_registry.py": [
        "test_loads_all_converters_from_dir",
        "test_get_known_schema_returns_correct_converter",
        "test_get_unknown_schema_returns_generic_converter"
      ],
      "test_skill_card_converter.py": [
        "test_converts_skill_to_3_requirements",
        "test_requirements_not_placeholder"
      ],
      "test_system_binder.py": [
        "test_exact_match_via_system_id",
        "test_fuzzy_match_via_title_overlap",
        "test_unmatched_requirement_system_id_none",
        "test_all_requirements_processed"
      ]
    },
    "integration": {
      "test_step03_integration.py": [
        "test_hades_entities_produce_nonplaceholder_requirements",
        "test_binding_rate_above_90_percent",
        "test_output_files_schema_valid",
        "test_step05_warning_count_reduced"
      ]
    }
  },

  "acceptance_criteria": {
    "functional": [
      "ConverterRegistry 自动发现并注册所有转换器",
      "5种核心转换器生成非占位符需求",
      "SystemBinder 精确匹配率 >70%，加模糊匹配后总绑定率 >90%",
      "RequirementValidator 正确统计占位符率",
      "所有输出文件通过 schema 验证"
    ]
  },

  "target_metrics": {
    "placeholder_rate": "100% → <25%",
    "system_binding_rate": "0% → >90%",
    "step05_warnings": "107 → <15",
    "quality_score": "18/100 → 65-75/100"
  }
}
