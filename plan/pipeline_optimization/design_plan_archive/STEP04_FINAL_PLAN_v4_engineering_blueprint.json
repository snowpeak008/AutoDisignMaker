{
  "step": "04",
  "name": "美术需求 (Art Requirements)",
  "version": "v4.0 Engineering Blueprint",
  "status": "pending",
  "priority": "high",

  "problems": {
    "current_issues": [
      "仅3条占位符资源",
      "无法从 designEntities 提取资产清单",
      "无市场参考数据",
      "无风格分析"
    ],
    "root_causes": [
      "无实体→资产转换器",
      "无品类参考库"
    ]
  },

  "module_structure": {
    "root": "pipeline/step_04_art_requirements/",
    "files": {
      "plugin.py": {
        "class": "Plugin",
        "inherits": "StagePlugin",
        "stage_id": "4",
        "execute_body_outline": [
          "1. run_import_step()",
          "2. step02_data = DataInheritor(ctx).load()",
          "3. skill_guidance = load_json(step00_skill_guidance_path)",
          "4. assets = EntityToAssetConverter.convert_all(step02_data.entities)",
          "5. market = MarketResearchSkill(market_data_path).analyze(step02_data.genre)",
          "6. registry = AssetRegistry.build(assets, market)",
          "7. 生成需求文档，写出文件，return StageResult"
        ]
      },
      "core/entity_to_asset_converter.py": {
        "class": "EntityToAssetConverter",
        "docstring": "将 designEntities 转换为结构化资产清单",
        "methods": [
          {
            "name": "convert_all",
            "signature": "(cls, entities: list[DesignEntity]) -> list[ArtAsset]"
          },
          {
            "name": "_convert_character",
            "signature": "(cls, entity: DesignEntity) -> list[ArtAsset]",
            "note": "角色实体 → [角色原画, 角色动画集, 角色UI头像]"
          },
          {
            "name": "_convert_skill",
            "signature": "(cls, entity: DesignEntity) -> list[ArtAsset]",
            "note": "技能实体 → [技能特效, 技能图标, 音效]"
          },
          {
            "name": "_convert_scene",
            "signature": "(cls, entity: DesignEntity) -> list[ArtAsset]",
            "note": "场景实体 → [场景原画, 场景地块集, 环境音效]"
          },
          {
            "name": "_convert_ui",
            "signature": "(cls, entity: DesignEntity) -> list[ArtAsset]",
            "note": "UI实体 → [UI设计稿, 图标集, 字体规范]"
          },
          {
            "name": "_convert_item",
            "signature": "(cls, entity: DesignEntity) -> list[ArtAsset]"
          },
          {
            "name": "_convert_generic",
            "signature": "(cls, entity: DesignEntity) -> list[ArtAsset]",
            "note": "兜底：entity name → 1条通用资产"
          }
        ],
        "data_class": {
          "name": "ArtAsset",
          "fields": {
            "id": "str",
            "name": "str",
            "type": "Literal['character_art','vfx','ui','icon','scene','audio','animation','font']",
            "entity_id": "str",
            "description": "str",
            "resolution": "str | None",
            "format": "str | None",
            "priority": "Literal['P0','P1','P2','P3']",
            "complexity": "Literal['xs','s','m','l','xl']",
            "reference_style": "str | None"
          }
        }
      },
      "core/market_research_skill.py": {
        "class": "MarketResearchSkill",
        "docstring": "从本地策划参考库读取市场风格数据，不做网络请求",
        "init_signature": "(self, market_data_path: Path)",
        "methods": [
          {
            "name": "analyze",
            "signature": "(self, genre: str) -> MarketAnalysis",
            "note": "读取 knowledge/market_data/{genre}.json"
          },
          {
            "name": "get_style_references",
            "signature": "(self, genre: str) -> list[StyleReference]"
          },
          {
            "name": "get_asset_benchmarks",
            "signature": "(self, genre: str) -> dict[str, int]",
            "returns": "{'character_art': 8, 'vfx': 20, 'ui': 30, ...}"
          }
        ],
        "data_classes": {
          "MarketAnalysis": {
            "fields": {
              "genre": "str",
              "art_style": "str",
              "color_palette": "list[str]",
              "reference_games": "list[str]",
              "asset_benchmarks": "dict[str, int]",
              "style_notes": "str"
            }
          },
          "StyleReference": {
            "fields": {
              "game_name": "str",
              "art_style": "str",
              "notable_elements": "list[str]"
            }
          }
        }
      },
      "core/asset_registry.py": {
        "class": "AssetRegistry",
        "docstring": "管理完整的资产目录，支持按类型/优先级/系统查询",
        "methods": [
          {
            "name": "build",
            "signature": "(cls, assets: list[ArtAsset], market: MarketAnalysis) -> AssetRegistry"
          },
          {
            "name": "by_type",
            "signature": "(self, asset_type: str) -> list[ArtAsset]"
          },
          {
            "name": "by_priority",
            "signature": "(self, priority: str) -> list[ArtAsset]"
          },
          {
            "name": "total_count",
            "signature": "(self) -> int"
          },
          {
            "name": "to_dict",
            "signature": "(self) -> dict",
            "note": "序列化为 asset_registry.json 格式"
          }
        ]
      }
    }
  },

  "data_files": {
    "knowledge/market_data/": {
      "purpose": "策划参考库（5个品类，每个20+参考游戏）",
      "files": [
        "roguelike.json",
        "fps.json",
        "rpg.json",
        "puzzle.json",
        "strategy.json"
      ],
      "per_file_schema": {
        "genre": "string",
        "art_style": "string",
        "color_palette": "array",
        "reference_games": [{"name": "str", "art_style": "str", "notable_elements": "array"}],
        "asset_benchmarks": {"character_art": "int", "vfx": "int", "ui": "int"}
      },
      "note": "禁止网络爬取，所有数据手工整理，法律安全"
    }
  },

  "data_contracts": {
    "input": {
      "from_step_02": ["design_entities.json"],
      "from_step_00": ["skill_guidance.json"],
      "from_knowledge": "knowledge/market_data/{genre}.json"
    },
    "output": {
      "asset_registry.json": "完整资产清单（>40条）",
      "UI需求.md": "UI资产需求文档（>15条）",
      "原画需求.md": "原画资产需求文档（>10条）",
      "特效需求.md": "特效资产需求文档（>10条）",
      "market_analysis.md": "市场风格分析报告"
    }
  },

  "implementation_tasks": [
    {"id": "T04-01", "task": "创建五层模块目录结构", "hours": 1, "status": "pending"},
    {"id": "T04-02", "task": "实现 ArtAsset dataclass", "hours": 1, "status": "pending"},
    {"id": "T04-03", "task": "实现 EntityToAssetConverter 的5个具体转换方法", "hours": 6, "status": "pending"},
    {"id": "T04-04", "task": "实现 EntityToAssetConverter.convert_all() + _convert_generic()", "hours": 2, "status": "pending"},
    {"id": "T04-05", "task": "创建 knowledge/market_data/ 下5个品类 JSON", "hours": 5, "status": "pending"},
    {"id": "T04-06", "task": "实现 MarketResearchSkill 全部方法", "hours": 4, "status": "pending"},
    {"id": "T04-07", "task": "实现 AssetRegistry.build() + by_type() + to_dict()", "hours": 3, "status": "pending"},
    {"id": "T04-08", "task": "实现 Markdown 需求文档生成器", "hours": 3, "status": "pending"},
    {"id": "T04-09", "task": "重构 plugin.py 为编排层", "hours": 2, "status": "pending"},
    {"id": "T04-10", "task": "单元测试（EntityToAssetConverter 各类型各1用例 = 5个）", "hours": 3, "status": "pending"},
    {"id": "T04-11", "task": "单元测试（MarketResearchSkill 3个用例）", "hours": 2, "status": "pending"},
    {"id": "T04-12", "task": "集成测试（Hades模板资产生成验证总数 >40）", "hours": 2, "status": "pending"}
  ],

  "test_cases": {
    "unit": {
      "test_entity_to_asset_converter.py": [
        "test_character_entity_produces_art_and_animation",
        "test_skill_entity_produces_vfx_and_icon",
        "test_scene_entity_produces_scene_art",
        "test_ui_entity_produces_ui_assets",
        "test_generic_entity_produces_at_least_one_asset"
      ],
      "test_market_research_skill.py": [
        "test_analyze_roguelike_returns_market_data",
        "test_missing_genre_raises_error",
        "test_asset_benchmarks_all_positive"
      ]
    },
    "integration": {
      "test_step04_integration.py": [
        "test_hades_entities_produce_40plus_assets",
        "test_ui_requirements_doc_has_15plus_items",
        "test_market_analysis_doc_generated",
        "test_all_output_files_present"
      ]
    }
  },

  "acceptance_criteria": {
    "functional": [
      "EntityToAssetConverter 处理5种核心实体类型",
      "asset_registry.json 包含 >40 条资产",
      "MarketResearchSkill 读取本地参考库（无网络调用）",
      "UI/原画/特效需求文档分别生成",
      "所有资产有 priority 和 complexity 字段"
    ]
  },

  "target_metrics": {
    "asset_count": "3 → 40-60",
    "market_analysis_rate": "0% → 100%",
    "quality_score": "12/100 → 60-70/100"
  }
}
